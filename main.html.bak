        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">12:00</span>
        <div class="schedule-content">
          <div class="schedule-event"><span class="schedule-badge badge-ctf">CTF</span>CTF Deadline — Flags Closed</div>
          <div class="schedule-detail">All submissions locked, leaderboard frozen</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">13:00</span>
        <div class="schedule-content">
