          <div class="schedule-detail">Teams registered, categories announced, first flags released</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">13:00</span>
        <div class="schedule-content">
          <div class="schedule-event">Lunch Break</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">14:30</span>
        <div class="schedule-content">
          <div class="schedule-event"><span class="schedule-badge badge-tech">TECH</span>Technical Sessions Block 1</div>
          <div class="schedule-detail">Parallel workshops — Web Security · Network Forensics · OSINT</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">17:00</span>
        <div class="schedule-content">
          <div class="schedule-event"><span class="schedule-badge badge-social">PANEL</span>Round Table: Cyber in Tunisia</div>
          <div class="schedule-detail">Expert panelists discuss the cybersecurity ecosystem &amp; career paths</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">19:00</span>
        <div class="schedule-content">
          <div class="schedule-event">Dinner &amp; Networking</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">21:00</span>
        <div class="schedule-content">
          <div class="schedule-event"><span class="schedule-badge badge-night">OVERNIGHT</span>CTF Night Session Begins</div>
          <div class="schedule-detail">Overnight CTF continues — food &amp; drinks provided, infrastructure on standby</div>
        </div>
      </div>
    </div>

    <div class="schedule-block" id="day2">
      <div class="schedule-item">
        <span class="schedule-time">08:00</span>
        <div class="schedule-content">
          <div class="schedule-event">Morning Coffee for CTF Survivors ☕</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">09:00</span>
        <div class="schedule-content">
          <div class="schedule-event"><span class="schedule-badge badge-tech">KEYNOTE</span>Offensive Security Deep Dive</div>
          <div class="schedule-detail">Penetration testing methodologies &amp; red team tactics</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">10:30</span>
        <div class="schedule-content">
