<!-- ABOUT -->
<section id="about">
  <div class="section-inner">
    <div class="about-grid">
      <div>
        <p class="eyebrow">// about uct</p>
        <h2 class="section-title">The Congress</h2>
        <div class="divider"></div>
        <p class="section-lead">
          Unmasking Cyber Threats (UCT) is a national cybersecurity congress organized by the
          IEEE Computer Science Chapter at ISIMA. Now in its second edition, UCT gathers students,
          professionals, and industry experts for two days of deep technical content, competitions,
          and high-value networking.
        </p>
        <p class="section-lead" style="margin-top:1rem;">
          The event runs a parallel CTF competition and technical challenge alongside a curated
          round table bringing prominent domain experts — a rare opportunity to learn, compete,
          and build your network in one place.
        </p>
        <div class="about-tags">
          <span class="tag">Cybersecurity</span>
          <span class="tag">CTF</span>
          <span class="tag">Round Table</span>
          <span class="tag">Technical Challenges</span>
          <span class="tag">Networking</span>
          <span class="tag">IEEE</span>
          <span class="tag">ISIMA</span>
        </div>
      </div>
      <div class="about-visual">
        <div class="terminal-line"><span class="prompt">$</span><span class="key">event</span></div>
        <div class="terminal-line"><span class="prompt">→</span><span class="val">Unmasking Cyber Threats — 2nd Ed.</span></div>
        <div class="terminal-line" style="margin-top:.5rem;"><span class="prompt">$</span><span class="key">organizer</span></div>
        <div class="terminal-line"><span class="prompt">→</span><span class="val">IEEE CS Chapter · ISIMA SB</span></div>
        <div class="terminal-line" style="margin-top:.5rem;"><span class="prompt">$</span><span class="key">date</span></div>
        <div class="terminal-line"><span class="prompt">→</span><span class="val">26 – 27 September 2025</span></div>
        <div class="terminal-line" style="margin-top:.5rem;"><span class="prompt">$</span><span class="key">location</span></div>
        <div class="terminal-line"><span class="prompt">→</span><span class="val">Mahdia, Tunisia</span></div>
        <div class="terminal-line" style="margin-top:.5rem;"><span class="prompt">$</span><span class="key">highlights</span></div>
        <div class="terminal-line"><span class="prompt">→</span><span class="val">CTF · Tech Challenge · Round Table</span></div>
        <div class="terminal-line" style="margin-top:.5rem;"><span class="prompt">$</span><span class="key">status</span></div>
        <div class="terminal-line"><span class="prompt">→</span><span class="val" style="color:var(--cyan);">REGISTRATION OPEN</span><span class="terminal-cursor"></span></div>
      </div>
    </div>
  </div>
</section>

<!-- PROGRAM -->
<section id="program">
  <div class="section-inner">
    <p class="eyebrow">// schedule</p>
    <h2 class="section-title">Program</h2>
    <div class="divider"></div>
    <p class="section-lead" style="margin-bottom:2rem;">
      Two packed days combining technical sessions, competitions, expert talks, and an overnight CTF.
    </p>

    <div class="day-tabs">
      <button class="day-tab active" onclick="switchDay(1)">Day 1 — Sep 26</button>
      <button class="day-tab" onclick="switchDay(2)">Day 2 — Sep 27</button>
    </div>

    <div class="schedule-block active" id="day1">
      <div class="schedule-item">
        <span class="schedule-time">08:30</span>
        <div class="schedule-content">
          <div class="schedule-event">Registration & Welcome</div>
          <div class="schedule-detail">Check-in, badge pickup, welcome coffee</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">09:30</span>
        <div class="schedule-content">
          <div class="schedule-event">Opening Ceremony</div>
          <div class="schedule-detail">IEEE CS Chapter · ISIMA SB leadership &amp; guests</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">10:30</span>
        <div class="schedule-content">
          <div class="schedule-event"><span class="schedule-badge badge-tech">KEYNOTE</span>Threat Landscape 2025</div>
