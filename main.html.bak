          <div class="schedule-detail">CTF winners, challenge winners, certificates, closing remarks</div>
        </div>
      </div>
      <div class="schedule-item">
        <span class="schedule-time">18:00</span>
        <div class="schedule-content">
          <div class="schedule-event">End of UCT 2</div>
        </div>
      </div>
