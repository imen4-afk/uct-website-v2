<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UCT 2 — Unmasking Cyber Threats</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* ── TOKENS ─────────────────────────────── */
    :root {
      --cyan:    #00e5ff;
      --red:     #ff2d55;
      --amber:   #ffb800;
      --white:   #f0f4f8;
      --mono:    'Share Tech Mono', monospace;
      --display: 'Rajdhani', sans-serif;
      --body:    'Inter', sans-serif;
    }
    [data-theme="dark"] {
      --bg:        #080c10;
      --bg2:       #0d1117;
      --bg3:       #111923;
      --surface:   #141d27;
      --border:    rgba(0,229,255,.15);
      --text:      #c8d6e5;
      --text-dim:  #5a7a94;
      --glow:      0 0 20px rgba(0,229,255,.25);
    }
    [data-theme="light"] {
      --bg:        #f0f4f8;
      --bg2:       #e4eaf2;
      --bg3:       #dae2ec;
      --surface:   #ffffff;
      --border:    rgba(0,100,160,.15);
      --text:      #1a2a3a;
      --text-dim:  #5a7a94;
      --glow:      0 0 20px rgba(0,100,160,.15);
    }

    /* ── RESET ──────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--body);
      font-size: 16px;
      line-height: 1.6;
      transition: background .3s, color .3s;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; }

    /* ── NOISE OVERLAY ──────────────────────── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: .4;
    }

    /* ── SCANLINE ───────────────────────────── */
    [data-theme="dark"] body::after {
      content: '';
      position: fixed; inset: 0;
      background: repeating-linear-gradient(
        0deg, transparent, transparent 2px,
        rgba(0,0,0,.03) 2px, rgba(0,0,0,.03) 4px
      );
      pointer-events: none;
      z-index: 0;
    }

    /* ── NAV ────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 clamp(1rem,4vw,3rem);
      height: 60px;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(12px);
    }
    .nav-logo {
      font-family: var(--mono);
      font-size: 1rem;
      color: var(--cyan);
      letter-spacing: .08em;
      display: flex; align-items: center; gap: .5rem;
    }
    .nav-logo span { color: var(--red); }
    .nav-links {
      display: flex; gap: 1.6rem; list-style: none;
    }
    .nav-links a {
      font-family: var(--display);
      font-size: .85rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--text-dim);
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--cyan); }

    .theme-toggle {
      background: none; border: 1px solid var(--border);
      border-radius: 4px;
      padding: .3rem .7rem;
      cursor: pointer;
      color: var(--text-dim);
      font-family: var(--mono);
      font-size: .75rem;
      transition: color .2s, border-color .2s;
      white-space: nowrap;
    }
    .theme-toggle:hover { color: var(--cyan); border-color: var(--cyan); }
    .hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--text-dim); transition: .3s; }
    .mobile-menu {
      display: none; position: fixed; top: 60px; left: 0; right: 0;
      background: var(--bg2); border-bottom: 1px solid var(--border);
      padding: 1rem 2rem; z-index: 99;
      flex-direction: column; gap: .8rem;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      font-family: var(--display); font-size: 1rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: .1em; color: var(--text-dim);
    }

    /* ── HERO ───────────────────────────────── */
    #home {
      position: relative;
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding: 6rem 1.5rem 3rem;
      overflow: hidden;
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 30%, transparent 80%);
    }
    .hero-glow {
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0,229,255,.07) 0%, transparent 70%);
      top: 50%; left: 50%; transform: translate(-50%,-55%);
      pointer-events: none;
    }
    .hero-eyebrow {
      font-family: var(--mono);
      font-size: .75rem;
      letter-spacing: .25em;
      color: var(--cyan);
      margin-bottom: 1.2rem;
      position: relative;
    }
    .hero-eyebrow::before, .hero-eyebrow::after {
      content: '//'; color: var(--red); margin: 0 .5rem;
    }
    h1.hero-title {
      font-family: var(--display);
      font-size: clamp(2.8rem, 8vw, 6.5rem);
      font-weight: 700;
      line-height: 1;
      letter-spacing: .02em;
      color: var(--white);
      position: relative;
      margin-bottom: .5rem;
    }
    [data-theme="light"] h1.hero-title { color: var(--text); }
    .hero-title .accent { color: var(--cyan); }
    .hero-title .accent-red { color: var(--red); }
    .hero-subtitle {
      font-family: var(--display);
      font-size: clamp(1rem, 3vw, 1.5rem);
      font-weight: 500;
      color: var(--text-dim);
      letter-spacing: .08em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
      position: relative;
    }
    .hero-organizer {
      font-family: var(--mono);
      font-size: .78rem;
      color: var(--text-dim);
      letter-spacing: .15em;
      margin-bottom: 2.5rem;
      position: relative;
    }
    .hero-cta {
      display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
      position: relative; margin-bottom: 3rem;
    }
    .btn-primary {
      background: var(--cyan);
      color: #000;
      font-family: var(--display);
      font-weight: 700;
      font-size: .85rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      padding: .75rem 2rem;
      border: none; cursor: pointer;
      clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
      transition: opacity .2s, transform .2s;
    }
    .btn-primary:hover { opacity: .85; transform: translateY(-2px); }
    .btn-outline {
      background: transparent;
      color: var(--cyan);
      font-family: var(--display);
      font-weight: 600;
      font-size: .85rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      padding: .73rem 2rem;
      border: 1px solid var(--cyan);
      cursor: pointer;
      transition: background .2s, color .2s;
    }
    .btn-outline:hover { background: rgba(0,229,255,.08); }

    /* COUNTDOWN */
    .countdown {
      display: flex; gap: 1.5rem; justify-content: center;
      position: relative;
    }
    .countdown-item {
      display: flex; flex-direction: column; align-items: center;
    }
    .countdown-num {
      font-family: var(--mono);
      font-size: clamp(2rem, 5vw, 3rem);
      color: var(--cyan);
      line-height: 1;
    }
    .countdown-label {
      font-family: var(--mono);
      font-size: .6rem;
      letter-spacing: .2em;
      color: var(--text-dim);
      margin-top: .3rem;
    }
    .countdown-sep {
      font-family: var(--mono);
      font-size: 2.5rem;
      color: var(--red);
      line-height: 1;
      align-self: flex-start;
      margin-top: .1rem;
    }

    /* STAT BAR */
    .stat-bar {
      position: relative;
      display: flex; justify-content: center; gap: clamp(1.5rem, 5vw, 4rem);
      padding: 1.2rem clamp(1rem, 4vw, 3rem);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: var(--bg2);
      flex-wrap: wrap;
    }
    .stat-item { text-align: center; }
    .stat-num {
      font-family: var(--display);
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 700;
      color: var(--cyan);
    }
    .stat-desc {
      font-family: var(--mono);
      font-size: .65rem;
      letter-spacing: .18em;
      color: var(--text-dim);
    }

    /* ── SECTIONS SHARED ────────────────────── */
    section { position: relative; z-index: 1; }
    .section-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 5rem clamp(1rem, 4vw, 3rem);
    }
    .eyebrow {
      font-family: var(--mono);
      font-size: .7rem;
      letter-spacing: .28em;
      color: var(--red);
      text-transform: uppercase;
      margin-bottom: .6rem;
    }
    h2.section-title {
      font-family: var(--display);
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 700;
      letter-spacing: .02em;
      color: var(--white);
      margin-bottom: 1rem;
    }
    [data-theme="light"] h2.section-title { color: var(--text); }
    .section-lead {
      color: var(--text-dim);
      max-width: 620px;
      font-size: .95rem;
      line-height: 1.75;
    }
    .divider {
      width: 48px; height: 2px;
      background: linear-gradient(90deg, var(--cyan), var(--red));
      margin: 1.2rem 0 2rem;
    }

    /* ── ABOUT ──────────────────────────────── */
    #about { background: var(--bg2); }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }
    .about-visual {
      position: relative;
      border: 1px solid var(--border);
      padding: 2rem;
      background: var(--surface);
    }
    .about-visual::before {
      content: '> UCT_2.exe';
      font-family: var(--mono);
      font-size: .7rem;
      color: var(--cyan);
      display: block;
      margin-bottom: 1rem;
    }
    .terminal-line {
      font-family: var(--mono);
      font-size: .8rem;
      color: var(--text-dim);
      margin: .3rem 0;
      display: flex; align-items: flex-start; gap: .5rem;
    }
    .terminal-line .prompt { color: var(--cyan); flex-shrink: 0; }
    .terminal-line .val { color: var(--white); }
    [data-theme="light"] .terminal-line .val { color: var(--text); }
    .terminal-line .key { color: var(--amber); }
    .terminal-cursor {
      display: inline-block;
      width: 8px; height: 14px;
      background: var(--cyan);
      animation: blink 1s step-end infinite;
      vertical-align: middle;
    }
    @keyframes blink { 50% { opacity: 0; } }
    .about-tags {
      display: flex; flex-wrap: wrap; gap: .5rem; margin-top: 1.5rem;
    }
    .tag {
      font-family: var(--mono);
      font-size: .68rem;
      letter-spacing: .1em;
      border: 1px solid var(--border);
      padding: .25rem .6rem;
      color: var(--cyan);
      background: rgba(0,229,255,.04);
    }

    /* ── PROGRAM ────────────────────────────── */
    #program { background: var(--bg); }
    .day-tabs {
      display: flex; gap: .5rem; margin-bottom: 2rem;
    }
    .day-tab {
      font-family: var(--display);
      font-size: .8rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      padding: .5rem 1.2rem;
      border: 1px solid var(--border);
      background: none;
      color: var(--text-dim);
      cursor: pointer;
      transition: .2s;
    }
    .day-tab.active, .day-tab:hover {
      border-color: var(--cyan); color: var(--cyan);
      background: rgba(0,229,255,.05);
    }
    .schedule-block { display: none; }
    .schedule-block.active { display: block; }
    .schedule-item {
      display: grid;
      grid-template-columns: 90px 1fr;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border);
      align-items: start;
    }
    .schedule-time {
      font-family: var(--mono);
      font-size: .75rem;
      color: var(--text-dim);
      padding-top: .15rem;
    }
    .schedule-content {}
    .schedule-event {
      font-family: var(--display);
      font-size: 1rem;
      font-weight: 600;
      color: var(--white);
      margin-bottom: .2rem;
    }
    [data-theme="light"] .schedule-event { color: var(--text); }
    .schedule-detail {
      font-size: .8rem;
      color: var(--text-dim);
    }
    .schedule-badge {
      display: inline-block;
      font-family: var(--mono);
      font-size: .6rem;
      letter-spacing: .1em;
      border: 1px solid;
      padding: .1rem .4rem;
      margin-right: .4rem;
      vertical-align: middle;
    }
    .badge-ctf { border-color: var(--red); color: var(--red); }
    .badge-tech { border-color: var(--cyan); color: var(--cyan); }
    .badge-social { border-color: var(--amber); color: var(--amber); }
    .badge-night { border-color: #a855f7; color: #a855f7; }

    /* ── CTF ───────────────────────────────── */
    #ctf { background: var(--bg2); }
    .ctf-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1px;
      border: 1px solid var(--border);
      background: var(--border);
      margin-top: 2rem;
    }
    .ctf-card {
      background: var(--surface);
      padding: 1.5rem;
      transition: background .2s;
    }
    .ctf-card:hover { background: var(--bg3); }
    .ctf-icon {
      font-size: 1.8rem;
      margin-bottom: .8rem;
    }
    .ctf-name {
      font-family: var(--display);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: .05em;
      color: var(--cyan);
      margin-bottom: .4rem;
    }
    .ctf-desc {
      font-size: .8rem;
      color: var(--text-dim);
      line-height: 1.6;
    }

    /* ── TRAINING ───────────────────────────── */
    #training { background: var(--bg); }
    .training-banner {
      border: 1px solid var(--amber);
      background: rgba(255,184,0,.04);
      padding: 1.5rem 2rem;
      display: flex; align-items: flex-start; gap: 1rem;
      margin-bottom: 2rem;
    }
    .training-banner .icon { font-size: 1.5rem; flex-shrink: 0; }
    .training-banner p { font-size: .9rem; color: var(--text-dim); }
    .training-banner strong { color: var(--amber); }
    .training-timeline {
      display: flex; flex-direction: column; gap: 0;
      position: relative;
    }
    .training-timeline::before {
      content: '';
      position: absolute; left: 16px; top: 0; bottom: 0;
      width: 1px; background: var(--border);
    }
    .tl-item {
      display: flex; gap: 1.5rem; align-items: flex-start;
      padding: 1rem 0;
    }
    .tl-dot {
      width: 33px; height: 33px; flex-shrink: 0;
      border: 1px solid var(--cyan);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      background: var(--bg);
      font-family: var(--mono); font-size: .65rem; color: var(--cyan);
      position: relative; z-index: 1;
    }
    .tl-content h4 {
      font-family: var(--display); font-weight: 700;
      font-size: .95rem; color: var(--white); margin-bottom: .2rem;
    }
    [data-theme="light"] .tl-content h4 { color: var(--text); }
    .tl-content p { font-size: .8rem; color: var(--text-dim); }

    /* ── NETWORKING ─────────────────────────── */
    #networking { background: var(--bg2); }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .feature-card {
      border: 1px solid var(--border);
      padding: 1.5rem;
      background: var(--surface);
      position: relative;
      overflow: hidden;
      transition: border-color .2s;
    }
    .feature-card:hover { border-color: var(--cyan); }
    .feature-card::after {
      content: '';
      position: absolute; top: 0; left: 0;
      width: 2px; height: 0;
      background: var(--cyan);
      transition: height .3s;
    }
    .feature-card:hover::after { height: 100%; }
    .feature-num {
      font-family: var(--mono);
      font-size: .7rem; color: var(--text-dim);
      margin-bottom: .8rem;
    }
    .feature-title {
      font-family: var(--display);
      font-weight: 700; font-size: 1rem;
      color: var(--white); margin-bottom: .5rem;
    }
    [data-theme="light"] .feature-title { color: var(--text); }
    .feature-desc { font-size: .82rem; color: var(--text-dim); line-height: 1.65; }

    /* ── VENUE ──────────────────────────────── */
    #venue { background: var(--bg); }
    .venue-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;
    }
    .venue-map {
      border: 1px solid var(--border);
      overflow: hidden; height: 300px; background: var(--surface);
      display: flex; align-items: center; justify-content: center;
    }
    .venue-map iframe { width: 100%; height: 100%; border: 0; filter: grayscale(1) invert(.85) hue-rotate(180deg); }
    [data-theme="light"] .venue-map iframe { filter: grayscale(.5); }
    .venue-info h3 {
      font-family: var(--display); font-weight: 700; font-size: 1.4rem;
      color: var(--white); margin-bottom: 1rem;
    }
    [data-theme="light"] .venue-info h3 { color: var(--text); }
    .venue-detail {
      display: flex; align-items: flex-start; gap: .8rem;
      margin-bottom: .8rem;
    }
    .venue-detail .icon { color: var(--cyan); font-size: 1rem; flex-shrink: 0; margin-top: .1rem; }
    .venue-detail p { font-size: .85rem; color: var(--text-dim); }
    .venue-detail strong { color: var(--text); }
    [data-theme="light"] .venue-detail strong { color: var(--text); }

    /* ── FAQ ────────────────────────────────── */
    #faq { background: var(--bg2); }
    .faq-list { display: flex; flex-direction: column; gap: 0; margin-top: 2rem; }
    .faq-item {
      border-bottom: 1px solid var(--border);
    }
    .faq-q {
      width: 100%; background: none; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.1rem 0;
      font-family: var(--display); font-weight: 600; font-size: .95rem;
      color: var(--white); text-align: left;
      gap: 1rem;
    }
    [data-theme="light"] .faq-q { color: var(--text); }
    .faq-icon {
      flex-shrink: 0; width: 20px; height: 20px;
      border: 1px solid var(--border); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: .7rem; color: var(--cyan);
      transition: transform .3s;
    }
    .faq-item.open .faq-icon { transform: rotate(45deg); border-color: var(--cyan); }
    .faq-a {
      max-height: 0; overflow: hidden;
      font-size: .85rem; color: var(--text-dim); line-height: 1.7;
      transition: max-height .35s ease, padding .3s;
    }
    .faq-item.open .faq-a { max-height: 300px; padding-bottom: 1.1rem; }

    /* ── CONTACT ────────────────────────────── */
    #contact { background: var(--bg); }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;
    }
    .contact-links { display: flex; flex-direction: column; gap: .8rem; }
    .contact-link {
      display: flex; align-items: center; gap: .8rem;
      font-size: .85rem; color: var(--text-dim);
      transition: color .2s;
    }
    .contact-link:hover { color: var(--cyan); }
    .contact-link .icon { font-size: 1rem; flex-shrink: 0; color: var(--cyan); }
    .social-row { display: flex; gap: .8rem; margin-top: 1.2rem; }
    .social-btn {
      font-family: var(--mono);
      font-size: .65rem; letter-spacing: .1em;
      border: 1px solid var(--border);
      padding: .45rem .9rem;
      color: var(--text-dim);
      transition: .2s;
      display: flex; align-items: center; gap: .4rem;
    }
    .social-btn:hover { border-color: var(--cyan); color: var(--cyan); }
    .register-box {
      border: 1px solid var(--cyan);
      padding: 2rem;
      background: rgba(0,229,255,.03);
      text-align: center;
    }
    .register-box h3 {
      font-family: var(--display); font-weight: 700;
      font-size: 1.3rem; color: var(--white); margin-bottom: .5rem;
    }
    [data-theme="light"] .register-box h3 { color: var(--text); }
    .register-box p { font-size: .85rem; color: var(--text-dim); margin-bottom: 1.5rem; }
    .register-box .note {
      font-family: var(--mono); font-size: .65rem;
      color: var(--text-dim); margin-top: .8rem;
    }

    /* ── FOOTER ─────────────────────────────── */
    footer {
      background: var(--bg2);
      border-top: 1px solid var(--border);
      padding: 2rem clamp(1rem, 4vw, 3rem);
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 1rem;
    }
    .footer-logo {
      font-family: var(--mono);
      font-size: .85rem; color: var(--cyan);
    }
    .footer-copy {
      font-family: var(--mono);
      font-size: .65rem; color: var(--text-dim);
    }

    /* ── RESPONSIVE ─────────────────────────── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .about-grid, .venue-grid, .contact-grid { grid-template-columns: 1fr; }
      .hero-glow { display: none; }
    }
  </style>
</head>
